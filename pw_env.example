# ━━ PolyWeather Bot v9.3 (pw_) ━━
# Copy this to .env and fill in your values.
# NEVER commit .env with real values!

# ── Required (4 secrets — sufficient for live trading) ──
TELEGRAM_TOKEN=          # Bot token from @BotFather
TELEGRAM_CHAT_ID=        # Your chat ID (send /start to @userinfobot)
POLY_PRIVATE_KEY=        # Wallet private key (0x...)
POLY_FUNDER=             # Funder/proxy wallet address (0x...)

# ── CLOB API (OPTIONAL — auto-derived from private_key+funder) ──
# If you provide these, they will be used directly.
# If you leave them empty, the bot will auto-derive credentials
# using py_clob_client_v2 from your POLY_PRIVATE_KEY + POLY_FUNDER.
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# ── Bot Settings ──
BANKROLL=20              # Starting bankroll in USD (default: 20)
                         # NOTE: Once the bot reads your wallet balance,
                         # Kelly sizing becomes 100% adaptive based on
                         # actual wallet balance. This $20 is ONLY used
                         # on the very first run before chain data exists.
DRY_RUN=true             # true = no real orders, false = live trading
FAST_SCAN=false          # true = 5-min new-markets-only scan

# ── New Model Settings (advanced, defaults are fine) ──
# LIQUIDITY_MIN_DEPTH=30 # Min orderbook depth in USD
# BOOTSTRAP_N=1000       # Bootstrap resampling iterations
# BOOTSTRAP_CONF=0.90    # Bootstrap confidence level
# DISPERSION_MAX_PP=3.0  # Max model dispersion in °C
# KELLY_F4_DRAWDOWN=0.15 # Drawdown level for f/4 Kelly
# KELLY_F3_DRAWDOWN=0.10 # Drawdown level for f/3 Kelly
