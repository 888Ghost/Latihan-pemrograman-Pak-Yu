# ═══════════════════════════════════════════════════════════════════
#  .env.example — Polymarket Weather Bot v13.1
#
#  Cara pakai lokal (testing di laptop sebelum deploy ke GitHub):
#    cp .env.example .env
#    → isi nilai asli di .env
#    → python -m src.main
#
#  Untuk GitHub Actions (production):
#    Masukkan SEMUA secret di:
#    GitHub Repo → Settings → Secrets and variables → Actions
#    JANGAN commit file .env ke repo — sudah ada di .gitignore
#
#  CATATAN: variabel yang tidak di-set akan pakai nilai default
#  yang sudah ditentukan di src/config.py. Bot tidak akan crash
#  karena variabel tidak ada (kecuali 4 yang REQUIRED di bawah).
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# REQUIRED — bot tidak akan start tanpa keempat ini
# ─────────────────────────────────────────────────────────────────

# Private key dari Bitget Wallet
# Cara export: Bitget Wallet → pilih jaringan ETH → Export Private Key
# Format: 0x + 64 karakter hex = total 66 karakter
# JANGAN PERNAH share, commit, atau kirim ke siapapun
POLY_PRIVATE_KEY=0x_your_64hex_eth_private_key_here

# Wallet address kamu (ETH dan Polygon menghasilkan alamat yang SAMA)
# Format: 0x + 40 karakter hex = total 42 karakter
# Ini publik — aman dibagikan, bukan private key
POLY_FUNDER=0x_your_wallet_address_here

# Telegram Bot Token
# Cara dapatkan: chat @BotFather di Telegram → /newbot → salin token
# Format: angka:huruf-angka (contoh: 1234567890:ABCxyz...)
TELEGRAM_TOKEN=<dari_@BotFather>

# Telegram Chat ID
# Cara dapatkan: chat @userinfobot di Telegram → lihat id: angka
# Format: angka (bisa negatif untuk group)
TELEGRAM_CHAT_ID=<dari_@userinfobot>

# ─────────────────────────────────────────────────────────────────
# OPTIONAL — bot pakai nilai default jika tidak di-set
# ─────────────────────────────────────────────────────────────────

# Modal awal dalam USD
# Default: 20 jika tidak di-set. Bot membaca balance on-chain (pUSD)
# di awal setiap run — nilai ini hanya fallback jika RPC gagal.
BANKROLL=20

# Mode simulasi
# true  = analisis+notifikasi saja, TIDAK ada order nyata (default)
# false = live trading, order sungguhan dikirim ke Polymarket
# Mulai dengan true, ubah ke false setelah validasi minimal 14 hari
DRY_RUN=true

# Scan mode
# true  = hanya market baru < MAX_AGE jam (default, fokus edge tertinggi)
# false = scan semua weather market (lebih luas, lebih lambat)
FAST_SCAN=true

# ─────────────────────────────────────────────────────────────────
# OPTIONAL — CLOB API credentials (auto-derived jika tidak di-set)
# ─────────────────────────────────────────────────────────────────
# Bot menggunakan L1 wallet signing (POLY_PRIVATE_KEY) secara langsung.
# Credentials ini hanya diperlukan untuk L2 HMAC auth (sedikit lebih
# cepat, dan memungkinkan cancel order via API key).
# Cara generate: jalankan generate_credentials.py di laptop lokal.
# Biarkan kosong untuk memulai — bot tetap bisa trading tanpa ini.
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# ─────────────────────────────────────────────────────────────────
# REFERENSI — nama secret yang perlu diisi di GitHub Secrets
# (sama persis dengan nama variabel di atas)
# ─────────────────────────────────────────────────────────────────
# POLY_PRIVATE_KEY     ← REQUIRED
# POLY_FUNDER          ← REQUIRED
# TELEGRAM_TOKEN       ← REQUIRED
# TELEGRAM_CHAT_ID     ← REQUIRED
# BANKROLL             ← optional, default 20
# DRY_RUN              ← optional, default true
# FAST_SCAN            ← optional, default true (dioverride di workflow)
# CLOB_API_KEY         ← optional
# CLOB_API_SECRET      ← optional
# CLOB_API_PASSPHRASE  ← optional
