# Polymarket wallet
# Run locally with: python main.py
# CLOB API credentials will be derived/created automatically by main.py
# when DRY_RUN=false and POLY_PRIVATE_KEY is present.
POLY_PRIVATE_KEY=POLY_PRIVATE_KEY
POLY_FUNDER=POLY_FUNDER
POLY_SIGNATURE_TYPE=3

# Deposit wallet / gasless relayer flow (new API users usually use POLY_SIGNATURE_TYPE=3).
# RELAYER_API_KEY=your_relayer_api_key
# RELAYER_API_KEY_ADDRESS=0xOWNER_ADDRESS
# RELAYER_URL=https://relayer-v2.polymarket.com/

# Optional: paste generated CLOB credentials here to avoid deriving them every startup.
# CLOB_API_KEY=your_clob_api_key
# CLOB_API_SECRET=your_clob_api_secret
# CLOB_API_PASSPHRASE=your_clob_api_passphrase

# Telegram notifications / commands
TELEGRAM_TOKEN=TELEGRAM_TOKEN
TELEGRAM_CHAT_ID=TELEGRAM_CHAT_ID

# Runtime mode
DRY_RUN=true
FAST_SCAN=true

# Hard safety caps for live testing
# 0 means "disabled" for USDC caps; MAX_LIVE_ORDERS defaults to 20.
MAX_ORDER_USDC=1
MAX_DAILY_USDC=2
MAX_LIVE_ORDERS=2
